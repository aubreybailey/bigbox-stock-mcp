{
  "manifest_version": 3,
  "name": "bigbox-stock",
  "version": "0.2.0",
  "description": "Check per-store pickup availability across retail chains by driving your own browser.",
  "author": "Aubrey Bailey",
  "homepage_url": "https://github.com/aubreybailey/bigbox-stock-mcp",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "bigbox-stock",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png" }
  },
  "background": {
    "service_worker": "sw.js",
    "scripts": ["sw.js"],
    "type": "module"
  },
  "permissions": ["tabs", "scripting", "cookies", "storage"],
  "host_permissions": [
    "https://www.target.com/*", "https://*.target.com/*",
    "https://www.bestbuy.com/*", "https://*.bestbuy.com/*",
    "https://www.lowes.com/*", "https://*.lowes.com/*",
    "https://www.walmart.com/*", "https://*.walmart.com/*",
    "https://www.homedepot.com/*", "https://*.homedepot.com/*",
    "https://www.gamestop.com/*", "https://*.gamestop.com/*",
    "https://www.microcenter.com/*", "https://*.microcenter.com/*",
    "https://www.costco.com/*", "https://*.costco.com/*",
    "https://www.tractorsupply.com/*", "https://*.tractorsupply.com/*",
    "https://www.cvs.com/*", "https://*.cvs.com/*",
    "https://www.walgreens.com/*", "https://*.walgreens.com/*",
    "https://www.acehardware.com/*", "https://*.acehardware.com/*",
    "https://www.harborfreight.com/*", "https://*.harborfreight.com/*",
    "https://www.menards.com/*", "https://*.menards.com/*",
    "https://api.zippopotam.us/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bigbox-stock@aubreybailey.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
