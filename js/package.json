{
  "name": "storecheck-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "bigbox-stock-mcp — MV3 extension + local bridge/MCP for per-store pickup checks.",
  "scripts": {
    "bridge": "node server/bridge.mjs",
    "client": "node server/test-client.mjs",
    "lint": "eslint .",
    "lint:ext": "web-ext lint --source-dir=extension --no-config-discovery",
    "build:ext": "web-ext build --source-dir=extension --artifacts-dir=dist --overwrite-dest --ignore-files=icons/make-icons.mjs",
    "test:unit": "node --test test/unit/*.test.mjs",
    "test:smoke": "node test/smoke.mjs",
    "test": "npm run test:unit && npm run test:smoke",
    "check": "npm run lint && npm run test:unit",
    "prepare": "git -C .. config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "web-ext": "^10.4.0"
  }
}
